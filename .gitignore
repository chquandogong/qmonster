# Build artefacts
/target

# Local-only secrets / environment
.env
.env.*
CLAUDE.local.md
# Claude Code per-project local state (settings, scheduled-task locks,
# rules cache). All contents are local-machine state, not project-shared.
/.claude/

# Local logs and databases (never tracked in any phase)
/logs/
*.sqlite
/*.sqlite

# Working docs — model-to-model raw drafts stay local by design
# (see docs/ai/WORKFLOWS.md §7)
/.docs/

# mission-spec plugin install slot (tool code, not project state)
/.mission-spec/

# .mission layer — team/CI phase:
#   Track: .mission/decisions/, .mission/evals/
#   Ignore: per-session state + snapshots + templates
/.mission/CURRENT_STATE.md
/.mission/snapshots/
/.mission/templates/

# Operator-owned pricing table (see config/pricing.example.toml)
config/pricing.toml
config/claude-settings.json
