# qmonster.tmux.conf.example
# Version: v0.4.0
# Date: 2026-04-20

# Keep default prefix
set -g prefix C-b
bind C-b send-prefix

# Add secondary prefix
set -g prefix2 C-g
bind C-g send-prefix -2

set -g mouse on
set -g history-limit 200000
set -g base-index 1
setw -g pane-base-index 1
set -sg escape-time 0
set -g renumber-windows on
set -g set-titles on
set -g allow-rename off
setw -g automatic-rename off
setw -g mode-keys vi
set -g status-keys vi

# Helper: rename current pane title
bind T command-prompt -p "Pane title" "select-pane -T '%%'"

# Helper: rename current window
bind W command-prompt -p "Window name" "rename-window '%%'"

# Qmonster launcher. Keep the config under the runtime root so the
# settings overlay can write threshold edits back with `w`.
# Override this path before sourcing if you keep the repo elsewhere.
set -g @qmonster_repo "$HOME/Qmonster"
set -g @qmonster_config "$HOME/.qmonster/config/qmonster.toml"
bind Q split-window -h -c "#{pane_current_path}" "cd #{@qmonster_repo} && QMONSTER_CONFIG=#{@qmonster_config} scripts/run-qmonster.sh"

# Navigate panes quickly
bind -r h select-pane -L
bind -r j select-pane -D
bind -r k select-pane -U
bind -r l select-pane -R

# Resize panes quickly
bind -r H resize-pane -L 5
bind -r J resize-pane -D 3
bind -r K resize-pane -U 3
bind -r L resize-pane -R 5
